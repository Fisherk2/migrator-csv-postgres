# PostgreSQL Connection Configuration Example
# WARNING: Copy this file to .env and NEVER commit the real .env file
# This file contains EXAMPLE values only - replace with your actual credentials

# Database Connection - Basic connection parameters for PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=changeme_this_is_example_password

# Superuser credentials (para CREATE DATABASE)
DB_ROOT_USER=postgres
DB_ROOT_PASSWORD=tu_contraseña_de_postgres

# Connection Pool - Optimizes database connection reuse
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=30
DB_POOL_IDLE_TIMEOUT=300

# SSL Configuration - Security settings for encrypted connections
DB_SSL_MODE=prefer
DB_SSL_CERT_PATH=/path/to/cert.pem

# Database Settings - Localization and character encoding
DB_TIMEZONE=UTC
DB_ENCODING=UTF8
DB_CLIENT_ENCODING=UTF8

# Connection Behavior - Timeout and retry settings
DB_CONNECTION_TIMEOUT=10
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=60000

# Logging - Database query logging configuration
DB_LOG_LEVEL=info
DB_LOG_QUERIES=false