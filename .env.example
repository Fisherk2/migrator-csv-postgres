# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Migrador CSV - PostgreSQL: Variables de Entorno
# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# ADVERTENCIA: Copia este archivo a .env y NUNCA commits el .env real
# Este archivo contiene valores de EJEMPLO - reemplaza con tus credenciales

# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# CONEXIÓN A BASE DE DATOS (OBLIGATORIO)
# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Host donde corre PostgreSQL (default: localhost)
DB_HOST=localhost

# Puerto de PostgreSQL (default: 5432)
DB_PORT=5432

# Nombre de la base de datos para el migrador
DB_NAME=migrator_ecommerce

# Usuario de la base de datos (con permisos CREATE/INSERT/SELECT)
DB_USER=migrator_user

# Contraseña del usuario (¡NUNCA usar valores reales en este archivo!)
DB_PASSWORD=tu_contraseña_secreta_aqui

# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# CONFIGURACIÓN DEL MIGRADOR (OPCIONAL)
# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Ruta al archivo YAML de configuración (default: config/default_migration.yaml)
MIGRATION_CONFIG_PATH=config/default_migration.yaml

# Nivel de logging: DEBUG, INFO, WARNING, ERROR (default: INFO)
MIGRATION_LOG_LEVEL=INFO

# Encoding para archivos CSV (default: UTF-8)
MIGRATION_CSV_ENCODING=UTF-8

# Tamaño del lote para inserciones (default: 1000)
MIGRATION_BATCH_SIZE=1000

# Timeout en segundos para operaciones de BD (default: 300)
MIGRATION_DB_TIMEOUT=300

# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# TESTING Y DEBUGGING (OPCIONAL)
# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Habilitar modo dry-run: solo valida, no inserta (default: false)
MIGRATION_DRY_RUN=false

# Mostrar estadísticas detalladas durante migración (default: false)
MIGRATION_VERBOSE=false

# Directorio para reportes de errores (default: reports/)
MIGRATION_REPORTS_DIR=reports/

# Habilitar profiling de rendimiento (default: false)
MIGRATION_PROFILE_PERFORMANCE=false

# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# CONFIGURACIÓN DE TESTS DE INTEGRACIÓN (OPCIONAL)
# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Habilitar tests de integración con PostgreSQL real (default: true)
TEST_DB_AVAILABLE=true

# Host de base de datos para tests (default: localhost)
TEST_DB_HOST=localhost

# Puerto de PostgreSQL para tests (default: 5432)
TEST_DB_PORT=5432

# Nombre de base de datos para tests (default: migrator_test)
TEST_DB_NAME=migrator_test

# Usuario de base de datos para tests (default: test_user)
TEST_DB_USER=test_user

# Contraseña de base de datos para tests (default: test_password)
TEST_DB_PASSWORD=test_password